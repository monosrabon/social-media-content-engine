# ============================================================
# SOCIAL MEDIA CONTENT ENGINE — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git!

# ============================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================
# Get from: https://supabase.com → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Direct URL for Prisma migrations (bypasses connection pooler)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ============================================================
# NEXTAUTH.JS AUTHENTICATION
# ============================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# SUPABASE (for storage/file uploads)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ============================================================
# OPENAI (for AI features)
# ============================================================
OPENAI_API_KEY="sk-proj-..."

# ============================================================
# N8N AUTOMATION
# ============================================================
# Your n8n instance URL (local: http://localhost:5678, cloud: https://your-n8n.app.n8n.cloud)
N8N_BASE_URL="http://localhost:5678"
# Secret token to authenticate webhook calls FROM our app TO n8n
N8N_WEBHOOK_SECRET="your-n8n-webhook-secret-change-this"
# Secret token to authenticate webhook calls FROM n8n TO our app
N8N_INCOMING_SECRET="your-n8n-incoming-secret-change-this"

# ============================================================
# EMAIL (optional - for reminders)
# ============================================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"

# ============================================================
# TELEGRAM (optional - for notifications)
# ============================================================
# TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# TELEGRAM_CHAT_ID="your-chat-id"

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ContentEngine"

# ============================================================
# SUPABASE MCP CONFIGURATION (for AI Assistants)
# ============================================================
# Found in Supabase Dashboard → Project Settings → General → Reference ID
# Or you can copy it from your NEXT_PUBLIC_SUPABASE_URL above
SUPABASE_PROJECT_REF="your-project-ref"

# Set to "true" to restrict the MCP server to read-only queries (recommended)
# Set to "false" if you want the AI to apply migrations or run mutating SQL
SUPABASE_MCP_READ_ONLY="true"
